# Pipa.ai 环境变量配置模板
# 复制此文件为 .env 并根据需要修改

# 项目配置
PROJECT_NAME="Pipa.ai"
PROJECT_VERSION="2.2.0"
PROJECT_STAGE="production"

# Agent 配置
ECHO_ENABLED=true
ELON_ENABLED=true
YUCI_ENABLED=true

# 安全配置
MAX_TOKENS_PER_CONVERSATION=20000
MAX_RETRY_ATTEMPTS=2
MAX_TASK_DURATION_HOURS=2
MAX_CONCURRENT_AGENTS=3

# 记忆配置
MEMORY_RETENTION_DAYS=30
CONVERSATION_RETENTION_DAYS=7
LOG_RETENTION_DAYS=14

# 路径配置
MEMORY_DIR="memory"
TASKS_DIR="tasks"
LOGS_DIR="logs"
BACKUPS_DIR="backups"

# API 配置（可选）
# GITHUB_TOKEN=""
# TWITTER_API_KEY=""
# TWITTER_API_SECRET=""
# OPENAI_API_KEY=""

# 监控配置
ENABLE_MONITORING=true
MONITORING_INTERVAL_MINUTES=30

# 日志配置
LOG_LEVEL="info"
LOG_FORMAT="markdown"